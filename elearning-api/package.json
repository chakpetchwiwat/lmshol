{
  "name": "elearning-api",
  "version": "2.2.0",
  "description": "API Backend for e-Learning WebApp MVP",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "npm run test:helpers && npm run test:security",
    "test:helpers": "node tests/visibility.helpers.node.test.js && node tests/auth.helpers.test.js && node tests/coursePermissions.test.js && node tests/courseStaff.service.test.js && node tests/admin.lessons.test.js && node tests/course.routes.test.js && node tests/user.helpers.test.js && node tests/user.serializers.test.js && node tests/user.flows.test.js && node tests/goal.notifications.test.js && node tests/certificateUrl.test.js && node tests/certificateSignatures.test.js && node tests/validationAndCache.test.js",
    "test:security": "node tests/security.config.test.js && node tests/loginProtection.test.js",
    "test:refactor-contracts": "node scripts/compare_refactor_contracts.js",
    "certificates:regenerate": "node scripts/regenerate_certificates_by_no.js",
    "db:migrate:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:demo": "tsx prisma/seed-demo.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.11.0",
    "@sparticuz/chromium": "^123.0.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "puppeteer-core": "^22.6.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "nodemon": "^3.1.0",
    "prisma": "^5.11.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
