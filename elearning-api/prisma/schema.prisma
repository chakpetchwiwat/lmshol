generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  password              String
  role                  String                 @default("user")
  department            String?
  pointsBalance         Int                    @default(0)
  status                String                 @default("ACTIVE")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  departmentId          String?
  employmentDate        DateTime?
  tierId                String?
  signatureImageUrl     String?
  signatureTitle        String?
  createdAnnouncements  Announcement[]         @relation("AnnouncementCreator")
  announcementViews     AnnouncementView[]     @relation("UserAnnouncementViews")
  gradedAssessments     AssessmentSubmission[] @relation("AssessmentGrader")
  assessmentSubmissions AssessmentSubmission[] @relation("AssessmentLearner")
  issuedCertificates    Certificate[]
  courseStaff           CourseStaff[]
  pointsLedger          PointsLedger[]
  QuizAttempt           QuizAttempt[]
  redeems               RedeemRequest[]
  departmentRef         Department?            @relation("DepartmentUsers", fields: [departmentId], references: [id])
  tier                  Tier?                  @relation(fields: [tierId], references: [id])
  certificates          UserCertificate[]
  enrollments           UserCourse[]
  progress              UserLessonProgress[]
  notifications         UserNotification[]

  @@index([status, departmentId, tierId])
  @@index([departmentId, status])
}

model UserCertificate {
  id             String    @id @default(uuid())
  userId         String
  title          String
  issuer         String
  issueDate      DateTime?
  expirationDate DateTime?
  noExpiration   Boolean   @default(false)
  credentialId   String?
  credentialUrl  String?
  fileUrl        String?
  fileKey        String?
  fileName       String?
  fileMimeType   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, issueDate])
  @@index([userId, createdAt])
}

model Course {
  id                 String                    @id @default(uuid())
  title              String
  description        String?
  categoryId         String?
  points             Int                       @default(0)
  status             String                    @default("DRAFT")
  image              String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  instructorAvatar   String?
  instructorBio      String?                   @default("ทีมงานผู้มีความเชี่ยวชาญเฉพาะด้านที่ผ่านประสบการณ์การทำงานในองค์กรชั้นนำ พร้อมถ่ายทอดทักษะระดับมืออาชีพให้คุณ")
  instructorName     String?                   @default("ทีมงานวิทยากรผู้เชี่ยวชาญ")
  instructorRole     String?                   @default("Enterprise Instructor")
  previewVideoUrl    String?
  rating             Float                     @default(4.8)
  reviewCount        Int                       @default(1240)
  studentCount       Int                       @default(5000)
  totalDuration      String?
  whatYouWillGet     String?
  whatYouWillLearn   String?
  visibleToAll       Boolean                   @default(true)
  isTemporary        Boolean                   @default(false)
  expiredAt          DateTime?
  instructorPresetId String?
  certificates       Certificate[]
  category           Category?                 @relation(fields: [categoryId], references: [id])
  instructorPreset   InstructorPreset?         @relation(fields: [instructorPresetId], references: [id])
  certificateSetting CourseCertificateSetting?
  departmentAccess   CourseDepartmentAccess[]
  staff              CourseStaff[]
  tierAccess         CourseTierAccess[]
  learningGoals      GoalCourse[]
  lessons            Lesson[]
  enrollments        UserCourse[]
}

model CourseStaff {
  id        String   @id @default(uuid())
  courseId  String
  userId    String
  role      String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId, role])
  @@index([courseId])
  @@index([userId])
  @@index([courseId, role])
  @@index([courseId, role, isPrimary])
}

model InstructorPreset {
  id                String   @id @default(uuid())
  name              String
  role              String?
  avatar            String?
  bio               String?
  signatureTitle    String?
  signatureImageUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  courses           Course[]
}

model Announcement {
  id           String                 @id @default(uuid())
  title        String
  description  String?
  image        String?
  type         String
  contentUrl   String?
  content      String?
  duration     String?
  passScore    Int?
  departmentId String?
  createdById  String?
  status       String                 @default("PUBLISHED")
  expiredAt    DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  scope        String                 @default("DEPARTMENT")
  creator      User?                  @relation("AnnouncementCreator", fields: [createdById], references: [id])
  department   Department?            @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  questions    AnnouncementQuestion[]
  views        AnnouncementView[]     @relation("AnnouncementViews")
}

model Category {
  id               String                     @id @default(uuid())
  name             String                     @unique
  order            Int                        @default(0)
  createdAt        DateTime                   @default(now())
  icon             String?                    @default("Grid")
  visibleToAll     Boolean                    @default(true)
  type             String?                    @default("FUNCTION")
  isTemporary      Boolean                    @default(false)
  expiredAt        DateTime?
  departmentAccess CategoryDepartmentAccess[]
  tierAccess       CategoryTierAccess[]
  courses          Course[]
}

model Department {
  id             String                     @id @default(uuid())
  name           String                     @unique
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  announcements  Announcement[]
  categoryAccess CategoryDepartmentAccess[]
  courseAccess   CourseDepartmentAccess[]
  learningGoals  LearningGoal[]
  users          User[]                     @relation("DepartmentUsers")
}

model Tier {
  id             String               @id @default(uuid())
  name           String               @unique
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  accessAdmin    Boolean              @default(false)
  order          Int                  @default(0)
  categoryAccess CategoryTierAccess[]
  courseAccess   CourseTierAccess[]
  users          User[]
}

model CategoryDepartmentAccess {
  categoryId   String
  departmentId String
  createdAt    DateTime   @default(now())
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([categoryId, departmentId])
}

model CategoryTierAccess {
  categoryId String
  tierId     String
  createdAt  DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tier       Tier     @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@id([categoryId, tierId])
}

model CourseDepartmentAccess {
  courseId     String
  departmentId String
  createdAt    DateTime   @default(now())
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([courseId, departmentId])
}

model CourseTierAccess {
  courseId  String
  tierId    String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tier      Tier     @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@id([courseId, tierId])
}

model Lesson {
  id                    String                 @id @default(uuid())
  courseId              String
  title                 String
  type                  String
  contentUrl            String?
  content               String?
  duration              String?
  points                Int                    @default(0)
  order                 Int                    @default(0)
  passScore             Int?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  assessmentSubmissions AssessmentSubmission[]
  course                Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions             Question[]
  quizAttempts          QuizAttempt[]
  progress              UserLessonProgress[]

  @@index([courseId, order])
}

model Question {
  id       String   @id @default(uuid())
  lessonId String
  text     String
  order    Int      @default(0)
  points   Int      @default(1)
  choices  Choice[]
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model Choice {
  id         String   @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id        String   @id @default(uuid())
  lessonId  String
  userId    String
  score     Int      @default(0)
  status    String   @default("PASSED")
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([lessonId, createdAt])
}

model AssessmentSubmission {
  id           String    @id @default(uuid())
  lessonId     String
  userId       String
  fileUrl      String?
  fileKey      String?
  fileName     String?
  fileMimeType String?
  note         String?
  score        Int?
  maxScore     Int       @default(10)
  status       String    @default("SUBMITTED")
  feedback     String?
  gradedById   String?
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  gradedBy     User?     @relation("AssessmentGrader", fields: [gradedById], references: [id])
  lesson       Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user         User      @relation("AssessmentLearner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId, status, submittedAt])
  @@index([userId, submittedAt])
  @@index([gradedById])
}

model AnnouncementQuestion {
  id             String               @id @default(uuid())
  announcementId String
  text           String
  order          Int                  @default(0)
  points         Int                  @default(1)
  choices        AnnouncementChoice[]
  announcement   Announcement         @relation(fields: [announcementId], references: [id], onDelete: Cascade)
}

model AnnouncementChoice {
  id         String               @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean              @default(false)
  question   AnnouncementQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model UserCourse {
  id              String    @id @default(uuid())
  userId          String
  courseId        String
  status          String    @default("IN_PROGRESS")
  progressPercent Float     @default(0)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  deadline        DateTime?
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, status, completedAt])
  @@index([userId, status, completedAt])
  @@index([userId, completedAt])
}

model UserLessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  progress    Float     @default(0)
  lastSeenAt  DateTime  @default(now())
  completedAt DateTime?
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model PointsLedger {
  id         String   @id @default(uuid())
  userId     String
  sourceType String
  sourceId   String?
  points     Int
  note       String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reward {
  id         String          @id @default(uuid())
  name       String
  pointsCost Int
  stock      Int             @default(0)
  status     String          @default("ACTIVE")
  image      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  maxPerUser Int             @default(1)
  redeems    RedeemRequest[]
}

model RedeemRequest {
  id          String   @id @default(uuid())
  userId      String
  rewardId    String
  pointsCost  Int
  status      String   @default("PENDING")
  adminNote   String?
  requestedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reward      Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningGoal {
  id                         String             @id @default(uuid())
  title                      String
  type                       String
  targetCount                Int                @default(1)
  expiryDate                 DateTime?
  scope                      String             @default("GLOBAL")
  departmentId               String?
  status                     String             @default("ACTIVE")
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  postAssignmentReminderDays Int?
  preDeadlineReminderDays    Int?
  postAssignmentReminderTime String?
  preDeadlineReminderTime    String?
  courses                    GoalCourse[]
  department                 Department?        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  notifications              UserNotification[]

  @@index([status, expiryDate, departmentId])
  @@index([scope, departmentId, status])
}

model GoalCourse {
  goalId   String
  courseId String
  course   Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  goal     LearningGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@id([goalId, courseId])
  @@index([courseId, goalId])
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model UserNotification {
  id           String        @id @default(uuid())
  userId       String
  goalId       String?
  type         String
  title        String
  message      String
  scheduledFor DateTime
  readAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  goal         LearningGoal? @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledFor, readAt])
  @@index([goalId, scheduledFor])
}

model AnnouncementView {
  id             String       @id @default(uuid())
  announcementId String
  userId         String
  score          Int?
  passed         Boolean?
  viewedAt       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  announcement   Announcement @relation("AnnouncementViews", fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation("UserAnnouncementViews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
}

model CertificateTemplate {
  id             String                     @id @default(uuid())
  name           String
  description    String?
  templateHtml   String
  templateCss    String
  orientation    CertificateOrientation     @default(LANDSCAPE)
  pageSize       String                     @default("A4")
  isDefault      Boolean                    @default(false)
  createdById    String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  certificates   Certificate[]
  courseSettings CourseCertificateSetting[]
}

model CourseCertificateSetting {
  id                  String                   @id @default(uuid())
  courseId            String                   @unique
  templateId          String
  enabled             Boolean                  @default(false)
  issueMode           CertificateIssueMode     @default(AUTOMATIC)
  signatureType       CertificateSignatureType @default(INSTRUCTOR)
  signerNameOverride  String?
  signerTitleOverride String?
  signatureImageUrl   String?
  signatureSlots      Json?
  passingScore        Int?
  expiryMonths        Int?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  course              Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  template            CertificateTemplate      @relation(fields: [templateId], references: [id])
}

model Certificate {
  id                String              @id @default(uuid())
  certificateNo     String              @unique
  verificationToken String              @unique
  userId            String
  courseId          String
  templateId        String
  status            CertificateStatus   @default(PENDING)
  pdfUrl            String?
  issuedById        String?
  issuedAt          DateTime            @default(now())
  expiresAt         DateTime?
  revokedById       String?
  revokedAt         DateTime?
  revokeReason      String?
  metadata          Json?
  course            Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  template          CertificateTemplate @relation(fields: [templateId], references: [id])
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
  @@index([verificationToken])
  @@index([certificateNo])
}

enum CertificateStatus {
  PENDING
  VALID
  REVOKED
  EXPIRED
  FAILED
}

enum CertificateIssueMode {
  AUTOMATIC
  MANUAL
}

enum CertificateSignatureType {
  INSTRUCTOR
  CUSTOM
  ORGANIZATION
}

enum CertificateOrientation {
  PORTRAIT
  LANDSCAPE
}
