generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String  @id @default(uuid())
  name          String
  email         String  @unique
  password      String
  role          String  @default("user") // "user" | "admin"
  department    String?
  departmentId  String?
  tierId        String?
  pointsBalance Int     @default(0)
  employmentDate DateTime?

  status    String   @default("ACTIVE") // "ACTIVE" | "INACTIVE"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departmentRef Department? @relation("DepartmentUsers", fields: [departmentId], references: [id], onDelete: SetNull)
  tier          Tier?       @relation(fields: [tierId], references: [id], onDelete: SetNull)
  enrollments   UserCourse[]
  progress      UserLessonProgress[]
  pointsLedger  PointsLedger[]
  redeems       RedeemRequest[]
  QuizAttempt   QuizAttempt[]
  createdAnnouncements Announcement[] @relation("AnnouncementCreator")
  announcementViews   AnnouncementView[] @relation("UserAnnouncementViews")
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  categoryId  String?
  instructorPresetId String?
  points      Int      @default(0)
  status      String   @default("DRAFT") // "DRAFT" | "PUBLISHED"
  image       String?
  visibleToAll Boolean @default(true)
  isTemporary Boolean  @default(false)
  expiredAt   DateTime?
  
  // Premium Fields
  instructorName   String?   @default("ทีมงานวิทยากรผู้เชี่ยวชาญ")
  instructorRole   String?   @default("Enterprise Instructor")
  instructorAvatar String?
  instructorBio    String?   @default("ทีมงานผู้มีความเชี่ยวชาญเฉพาะด้านที่ผ่านประสบการณ์การทำงานในองค์กรชั้นนำ พร้อมถ่ายทอดทักษะระดับมืออาชีพให้คุณ")
  previewVideoUrl  String?   // YouTube embed or Vercel URL
  totalDuration    String?   // override e.g. "120 ชม."
  whatYouWillLearn String?   @db.Text // JSON string list
  whatYouWillGet   String?   @db.Text // JSON string list
  rating           Float     @default(4.8)
  reviewCount      Int       @default(1240)
  studentCount     Int       @default(5000)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category?    @relation(fields: [categoryId], references: [id])
  instructorPreset InstructorPreset? @relation(fields: [instructorPresetId], references: [id], onDelete: SetNull)
  lessons     Lesson[]
  enrollments UserCourse[]
  departmentAccess CourseDepartmentAccess[]
  tierAccess       CourseTierAccess[]
  learningGoals    GoalCourse[]
}

model InstructorPreset {
  id        String   @id @default(uuid())
  name      String
  role      String?
  avatar    String?
  bio       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  description String?
  image       String?
  type        String
  contentUrl  String?
  content     String?  @db.Text
  duration    String?
  passScore   Int?
  scope       String   @default("DEPARTMENT") // "GLOBAL" | "DEPARTMENT"
  departmentId String?
  createdById String?
  status      String   @default("PUBLISHED")
  expiredAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  creator    User?      @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  questions  AnnouncementQuestion[]
  views      AnnouncementView[] @relation("AnnouncementViews")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String?  @default("Grid")
  type      String?  @default("FUNCTION") // LEADERSHIP | FUNCTION | INNOVATION
  order     Int      @default(0)
  visibleToAll Boolean @default(true)
  isTemporary Boolean @default(false)
  expiredAt   DateTime?
  createdAt DateTime @default(now())

  courses Course[]
  departmentAccess CategoryDepartmentAccess[]
  tierAccess       CategoryTierAccess[]
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]                 @relation("DepartmentUsers")
  courseAccess CourseDepartmentAccess[]
  categoryAccess CategoryDepartmentAccess[]
  learningGoals  LearningGoal[]
  announcements  Announcement[]
}

model Tier {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  accessAdmin Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  courseAccess CourseTierAccess[]
  categoryAccess CategoryTierAccess[]
}

model CategoryDepartmentAccess {
  categoryId   String
  departmentId String
  createdAt    DateTime @default(now())

  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([categoryId, departmentId])
}

model CategoryTierAccess {
  categoryId String
  tierId     String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tier     Tier     @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@id([categoryId, tierId])
}

model CourseDepartmentAccess {
  courseId     String
  departmentId String
  createdAt    DateTime @default(now())

  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([courseId, departmentId])
}

model CourseTierAccess {
  courseId  String
  tierId    String
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tier   Tier   @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@id([courseId, tierId])
}

model Lesson {
  id         String   @id @default(uuid())
  courseId   String
  title      String
  type       String // "video" | "pdf" | "article"
  contentUrl String?
  content    String? // New field for rich text content
  duration   String?
  points     Int      @default(0)
  order      Int      @default(0)
  passScore  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course       Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress     UserLessonProgress[]
  questions    Question[]
  quizAttempts QuizAttempt[]
}

model Question {
  id       String @id @default(uuid())
  lessonId String
  text     String
  order    Int    @default(0)
  points   Int    @default(1)

  lesson  Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  choices Choice[]
}

model Choice {
  id         String  @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id        String   @id @default(uuid())
  lessonId  String
  userId    String
  score     Int      @default(0)
  status    String   @default("PASSED") // "PASSED" | "FAILED"
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnnouncementQuestion {
  id             String @id @default(uuid())
  announcementId String
  text           String
  order          Int    @default(0)
  points         Int    @default(1)

  announcement Announcement        @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  choices      AnnouncementChoice[]
}

model AnnouncementChoice {
  id         String  @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)

  question AnnouncementQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model UserCourse {
  id              String    @id @default(uuid())
  userId          String
  courseId        String
  status          String    @default("IN_PROGRESS") // "NOT_STARTED" | "IN_PROGRESS" | "COMPLETED"
  progressPercent Float     @default(0)
  deadline        DateTime?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model UserLessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  progress    Float     @default(0) // 0-100
  lastSeenAt  DateTime  @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model PointsLedger {
  id         String   @id @default(uuid())
  userId     String
  sourceType String // "course" | "reward_adjust" | "redeem"
  sourceId   String? // ID of course or redeem request
  points     Int // positive for earn, negative for spend
  note       String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reward {
  id         String   @id @default(uuid())
  name       String
  pointsCost Int
  stock      Int      @default(0)
  maxPerUser Int      @default(1)
  status     String   @default("ACTIVE") // "ACTIVE" | "INACTIVE"
  image      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  redeems RedeemRequest[]
}

model RedeemRequest {
  id          String   @id @default(uuid())
  userId      String
  rewardId    String
  pointsCost  Int
  status      String   @default("PENDING") // "PENDING" | "APPROVED" | "FULFILLED" | "REJECTED" | "CANCELLED"
  adminNote   String?
  requestedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
}

model LearningGoal {
  id           String   @id @default(uuid())
  title        String
  type         String   // "ANY" | "SPECIFIC"
  targetCount  Int      @default(1)
  expiryDate   DateTime?
  scope        String   @default("GLOBAL") // "GLOBAL" | "DEPARTMENT"
  departmentId String?
  status       String   @default("ACTIVE") // "ACTIVE" | "ARCHIVED"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses      GoalCourse[]
}

model GoalCourse {
  goalId   String
  courseId String

  goal   LearningGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([goalId, courseId])
}

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model AnnouncementView {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  score          Int?     // For quiz type
  passed         Boolean? // For quiz type
  viewedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  announcement Announcement @relation("AnnouncementViews", fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation("UserAnnouncementViews", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
}
