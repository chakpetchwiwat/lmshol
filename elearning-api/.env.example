PORT=5000
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development

# Prisma Database URLs
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/database"

# Security baseline
ALLOWED_ORIGINS="https://app.yourdomain.com,https://admin.yourdomain.com"
TRUST_PROXY=false
API_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
SECURITY_ENABLE_DEFAULT_RATE_LIMIT=true
DEFAULT_RATE_LIMIT_WINDOW_MS=900000
DEFAULT_RATE_LIMIT_MAX=300
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=600000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_FAILURE_WINDOW_MS=900000
AUTH_LOGIN_LOCKOUT_MAX_FAILURES=5
AUTH_LOGIN_LOCKOUT_MS=900000
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=30
ADMIN_ANALYTICS_RATE_LIMIT_WINDOW_MS=300000
ADMIN_ANALYTICS_RATE_LIMIT_MAX=60
UPLOAD_MAX_FILE_SIZE_MB=25

# Supabase (if used for storage/etc.)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
